# App
APP_ENV=local
APP_BASE_URL=http://localhost
COMPOSE_PROJECT_NAME=vod-platform

# Frontend
VITE_API_BASE_URL=/api/v1
VITE_HLS_BASE_URL=/hls

# Backend API
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
JWT_SECRET=change-me-use-a-long-random-secret
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=7
CORS_ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vod_platform
POSTGRES_USER=vod_app
POSTGRES_PASSWORD=change-me
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/vod_platform
SPRING_DATASOURCE_USERNAME=vod_app
SPRING_DATASOURCE_PASSWORD=change-me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=vod_app
RABBITMQ_PASSWORD=change-me
RABBITMQ_ENCODING_QUEUE=video-encoding-queue

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=vod_minio
MINIO_SECRET_KEY=change-me
MINIO_BUCKET_RAW=vod-raw
MINIO_BUCKET_HLS=vod-hls
MINIO_BUCKET_THUMBNAILS=vod-thumbnails

# Uploads
MAX_UPLOAD_SIZE_MB=2048
ALLOWED_VIDEO_MIME_TYPES=video/mp4,video/x-matroska,video/webm,video/quicktime
TEMP_UPLOAD_DIR=/tmp/vod-uploads

# Worker
WORKER_CONCURRENCY=1
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
HLS_SEGMENT_SECONDS=6
HLS_TARGET_HEIGHT=720
WORKER_TEMP_DIR=/tmp/vod-worker

# Nginx / deployment
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
PUBLIC_DOMAIN=localhost
LETSENCRYPT_EMAIL=change-me@example.com

# Optional later AWS extension
AWS_REGION=
AWS_S3_BUCKET=
AWS_CLOUDFRONT_DOMAIN=
